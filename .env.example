# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your-secret-key-here
PORT=5000

# Google Generative AI API Key
# Get your API key from: https://ai.google.dev/
# Leave empty if you don't want page summarization feature
GENAI_API_KEY=your_genai_api_key_here

# VirusTotal API Key
# Get your API key from: https://www.virustotal.com/gui/home/upload
# Leave empty if you don't want VirusTotal fallback for low-confidence predictions
VT_API_KEY=your_virustotal_api_key_here

# Feature Flags
# Set to 'false' to disable page summarization (reduces API costs)
ENABLE_SUMMARY=true
